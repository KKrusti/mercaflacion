# basket-cost — variables de entorno para desarrollo local
# Copia este fichero a .env y rellena los valores reales.
# NUNCA subas .env al repositorio (ya está en .gitignore).

# ── Servidor ─────────────────────────────────────────────────────────────────
# Puerto TCP en el que escucha el devserver (por defecto: 8080)
PORT=8080

# ── Base de datos (Neon PostgreSQL) ──────────────────────────────────────────
# Connection string de Neon. En Vercel se inyecta automáticamente como DATABASE_URL
# cuando conectas el proyecto a una base de datos Neon.
# Para desarrollo local, cópialo desde: Vercel → tu proyecto → Settings → Environment Variables
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── Autenticación ─────────────────────────────────────────────────────────────
# Clave secreta para firmar los JWT. OBLIGATORIA.
# Genera una clave fuerte con: openssl rand -base64 32
JWT_SECRET=cambia-esto-genera-con-openssl-rand-base64-32

# ── Ingesta de correo (opcional) ──────────────────────────────────────────────
# Clave AES-256 para cifrar las contraseñas de aplicación de Gmail guardadas en BD.
# Genera con: openssl rand -hex 32
# Si no se define, la funcionalidad de ingesta por correo queda desactivada.
EMAIL_ENCRYPTION_KEY=

# Token secreto que protege el endpoint GET /api/cron/email-poll.
# Ponlo en el header X-Cron-Secret al llamar al endpoint manualmente.
# Vercel Cron Jobs lo envía automáticamente si se configura en vercel.json.
CRON_SECRET=

# Intervalo de polling para el devserver (por defecto: 48h).
# Ejemplos: 48h, 72h, 24h. No afecta a Vercel (usa el schedule del cron).
EMAIL_POLL_INTERVAL=48h
